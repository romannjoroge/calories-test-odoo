<odoo>
    <record id="action_calorie_profile" model="ir.actions.act_window">
        <field name="name">Profiles</field>
        <field name="res_model">calorie.profile</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_calorie_meal_log" model="ir.actions.act_window">
        <field name="name">Meal logs</field>
        <field name="res_model">calorie.meal.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_calorie_root" name="Calorie Advisor" sequence="10"/>
    <menuitem id="menu_calorie_profiles" name="Profiles" parent="menu_calorie_root" action="calories_test_odoo.action_calorie_profile" sequence="10"/>
    <menuitem id="menu_calorie_meals" name="Meal logs" parent="menu_calorie_root" action="calories_test_odoo.action_calorie_meal_log" sequence="20"/>
</odoo>
